# ============================================================
# SCC-NG — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env no Git!
# ============================================================

# --- Banco de Dados PostgreSQL ---
POSTGRES_USER=scc_user
POSTGRES_PASSWORD=TROQUE_POR_UMA_SENHA_FORTE
POSTGRES_DB=scc_ng_db

# --- Autenticação JWT ---
# Gere uma chave segura com: openssl rand -base64 64
JWT_SECRET=TROQUE_POR_UMA_CHAVE_SECRETA_MUITO_LONGA_E_ALEATORIA
JWT_EXPIRES_IN=8h
